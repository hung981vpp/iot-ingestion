{
  "info": {
    "name": "FIT4110 Lab05 Compose Smoke Tests",
    "_postman_id": "6aab1173-63a0-4b62-a8e6-9c985c68a3d7",
    "description": "Smoke tests for the Lab 05 Docker Compose stack.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "API health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('API health returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('API status is ok', function () {",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});",
              "pm.test('API service name is iot-ingestion', function () {",
              "  pm.expect(pm.response.json().service).to.eql('iot-ingestion');",
              "});",
              "pm.test('API version is 0.5.0', function () {",
              "  pm.expect(pm.response.json().version).to.eql('0.5.0');",
              "});",
              "pm.test('API health response is JSON', function () {",
              "  pm.response.to.have.header('Content-Type');",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "AI health",
      "request": {
        "method": "GET",
        "url": "{{aiBaseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('AI health returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('AI status is ok', function () {",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});",
              "pm.test('AI service name is ai-service', function () {",
              "  pm.expect(pm.response.json().service).to.eql('ai-service');",
              "});",
              "pm.test('AI version is 0.5.0', function () {",
              "  pm.expect(pm.response.json().version).to.eql('0.5.0');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "AI predict",
      "request": {
        "method": "POST",
        "url": "{{aiBaseUrl}}/predict"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('AI predict returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Prediction contains objects', function () {",
              "  pm.expect(pm.response.json().objects).to.be.an('array').that.is.not.empty;",
              "});",
              "pm.test('Prediction contains person', function () {",
              "  pm.expect(pm.response.json().objects).to.include('person');",
              "});",
              "pm.test('Prediction confidence count matches object count', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.confidence).to.be.an('array').with.lengthOf(body.objects.length);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create reading",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-10T09:50:00+07:00\"\n}"
        },
        "url": "{{baseUrl}}/readings"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create reading returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Reading accepted', function () {",
              "  pm.expect(pm.response.json().accepted).to.eql(true);",
              "});",
              "pm.test('Created reading has an id', function () {",
              "  pm.expect(pm.response.json().reading_id).to.match(/^R-\\d{8}-\\d{4}$/);",
              "});",
              "pm.test('Created reading keeps device id', function () {",
              "  pm.expect(pm.response.json().device_id).to.eql('ESP32-LAB-A01');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List latest readings",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": "{{baseUrl}}/readings/latest"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Latest readings returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Latest readings contains items', function () {",
              "  pm.expect(pm.response.json().items).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
