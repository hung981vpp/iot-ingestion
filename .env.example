# API configuration
APP_HOST=0.0.0.0
APP_PORT=8000
AUTH_TOKEN=local-dev-token
SERVICE_NAME=iot-ingestion
SERVICE_VERSION=0.5.0
ENV=local

# Database configuration
POSTGRES_USER=lab05
POSTGRES_PASSWORD=lab05pass
POSTGRES_DB=iotdb

# Partner services over hotspot/LAN. Update these at the start of Buoi 6.
CORE_SERVICE_URL=
ANALYTICS_SERVICE_URL=
REQUEST_TIMEOUT=5

# HiveMQ / MQTT configuration. Do not commit real passwords.
MQTT_HOST=
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_INPUT_TOPIC=smart-campus/raw/iot/environment
MQTT_SENSOR_OUTPUT_TOPIC=smart-campus/events/sensor
MQTT_TELEMETRY_OUTPUT_TOPIC=smart-campus/events/telemetry
MQTT_CLIENT_ID=iot-ingestion-worker
MQTT_PUBLISH_CONTRACT_EVENTS=false
DEVICE_REGISTRY_PATH=data/IoT_device_registry.csv

# Additional environment variables for AI service could be added here
